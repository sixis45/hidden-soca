---
import data from "../data/spots.json";
const { categories, spots } = data;
const base = import.meta.env.BASE_URL;
---
<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>

<div class="map-shell">
  <div class="filters" id="spot-filters">
    <button class="chip is-active" data-cat="all">All spots</button>
    {categories.map((c) => (
      <button class="chip" data-cat={c.id} style={`--chip:${c.color}`}>
        <span class="dot"></span>{c.label}
      </button>
    ))}
  </div>
  <div id="map" role="application" aria-label="Map of hidden spots in the Soča Valley"></div>
</div>

<script
  src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
  crossorigin=""
  is:inline
></script>

<script define:vars={{ categories, spots, base }} is:inline>
  function initMap() {
    if (typeof L === "undefined") { return setTimeout(initMap, 60); }

    const colorById = Object.fromEntries(categories.map((c) => [c.id, c.color]));

    const map = L.map("map", { scrollWheelZoom: false }).setView([46.28, 13.62], 11);

    L.tileLayer("https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png", {
      maxZoom: 17,
      attribution:
        'Map data: &copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors, ' +
        '<a href="https://opentopomap.org">OpenTopoMap</a> (CC-BY-SA)',
    }).addTo(map);

    const layers = {};
    categories.forEach((c) => (layers[c.id] = L.layerGroup().addTo(map)));
    const bounds = [];

    spots.forEach((s) => {
      const color = colorById[s.type] || "#18a89f";
      const marker = L.circleMarker([s.lat, s.lng], {
        radius: 9,
        color: "#fff",
        weight: 2,
        fillColor: color,
        fillOpacity: 1,
      });
      const link = s.post ? `<a href="${base}blog/${s.post}">Read the guide →</a>` : "";
      marker.bindPopup(
        `<strong>${s.name}</strong><br>${s.blurb}<br>${link}`
      );
      marker.addTo(layers[s.type] || map);
      bounds.push([s.lat, s.lng]);
    });

    if (bounds.length) map.fitBounds(bounds, { padding: [40, 40] });

    // Category filtering
    const filterBar = document.getElementById("spot-filters");
    filterBar.addEventListener("click", (e) => {
      const btn = e.target.closest(".chip");
      if (!btn) return;
      filterBar.querySelectorAll(".chip").forEach((b) => b.classList.remove("is-active"));
      btn.classList.add("is-active");
      const cat = btn.dataset.cat;
      categories.forEach((c) => {
        const show = cat === "all" || cat === c.id;
        if (show) map.addLayer(layers[c.id]);
        else map.removeLayer(layers[c.id]);
      });
    });
  }
  initMap();
</script>

<style>
  .map-shell {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    background: #fff;
  }
  #map {
    height: clamp(380px, 64vh, 640px);
    width: 100%;
    z-index: 1;
  }
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0.85rem;
    border-bottom: 1px solid var(--line);
    background: var(--paper);
  }
  .chip {
    --chip: #1f3a2c;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font: 600 0.82rem/1 var(--font-sans);
    color: var(--ink);
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.45rem 0.8rem;
    cursor: pointer;
  }
  .chip .dot {
    width: 9px; height: 9px; border-radius: 50%;
    background: var(--chip);
  }
  .chip.is-active { background: var(--ink); color: #fff; border-color: var(--ink); }
  .chip:hover { border-color: var(--soca); }
  :global(.leaflet-popup-content) { font-family: var(--font-sans); line-height: 1.4; }
  :global(.leaflet-popup-content a) { color: var(--soca-deep); font-weight: 700; }
</style>
