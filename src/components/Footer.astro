---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---
<footer class="site-footer">
  <div class="wrap inner">
    <div>
      <span class="mark mono">HIDDEN <strong>SOČA</strong></span>
      <p class="muted">Off-the-beaten-path guide to the Soča Valley & western Slovenia. Ground-truthed locally.</p>
    </div>
    <nav>
      <a href={base}>Map</a>
      <a href={`${base}blog`}>Blog</a>
    </nav>
  </div>
  <div class="wrap copyright muted">© {year} Hidden Soča</div>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    border-top: 1px solid var(--line);
    background: var(--paper-2);
    padding: 2.5rem 0 1.5rem;
  }
  .inner { display: flex; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
  .inner .mark { color: var(--ink); letter-spacing: 0.04em; }
  .inner .mark strong { color: var(--soca-deep); }
  .muted { color: var(--ink-soft); font-size: 0.92rem; }
  .inner p { max-width: 38ch; margin: 0.4rem 0 0; }
  .inner nav { display: flex; flex-direction: column; gap: 0.4rem; }
  .inner nav a { text-decoration: none; color: var(--ink); font-weight: 600; }
  .copyright { margin-top: 1.5rem; font-size: 0.82rem; }
</style>
